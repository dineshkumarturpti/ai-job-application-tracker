# Copy this file to .env and fill in real values. Never commit the real .env file.

# Postgres connection string. Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/job_tracker

# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Your OpenAI key. Get one at https://platform.openai.com/api-keys
# This key stays on the server -- it is never sent to the browser.
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-5.4-mini

# Where your frontend runs, for CORS. Add more origins in app/main.py if needed.
FRONTEND_ORIGIN=http://localhost:5173
